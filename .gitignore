# ══════════════════════════════════════════════════════════════════════════════
# .gitignore — ecommerce-eks
# ══════════════════════════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
wheels/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env/
.python-version

# ── Environment variable files ────────────────────────────────────────────────
# NEVER commit secrets or credentials
.env
.env.*
!.env.example                          # allow the example template
*.local

# ── AWS credentials ───────────────────────────────────────────────────────────
.aws/
aws-exports.js
credentials
*.pem
*.key
*.p12
*.pfx

# ── Terraform (if added later) ────────────────────────────────────────────────
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform/
.terraform.lock.hcl
terraform.tfplan
# allow env tfvars
!terraform/environments/dev/terraform.tfvars
!terraform/environments/prod/terraform.tfvars

# ── Node / Frontend tooling (if you add a build step later) ──────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/
.yarn/
dist/
.next/
.nuxt/
.cache/

# ── Docker ────────────────────────────────────────────────────────────────────
# Don't commit built images or layer caches
*.tar
docker-compose.override.yml

# ── Kubernetes sensitive files ────────────────────────────────────────────────
# kubeconfig files may contain cluster credentials
kubeconfig
kubeconfig.*
*.kubeconfig
.kube/

# ── IDE & editor ──────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json              # allow recommended extensions list
!.vscode/settings.json.example
.idea/
*.iml
*.iws
*.ipr
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ── OS generated ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
log/
pip-log.txt
pip-delete-this-directory.txt

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
coverage.xml
coverage/
htmlcov/
.tox/
.nox/
nosetests.xml
test-results/
junit.xml

# ── Type checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/
.ruff_cache/

# ── Database ──────────────────────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db

# ── Alembic ───────────────────────────────────────────────────────────────────
# Keep migrations but ignore auto-generated lock files
alembic/versions/__pycache__/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Misc ──────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
*.orig
*.patch
tmp/
temp/
scratch/